---
# Redmine container settings
redmine_image: "redmine:6.1"
redmine_host_port: 80
redmine_container_port: 3000
redmine_container_name: "redmine"
redmine_restart_policy: "unless-stopped"

# DB settings
# Supported values for redmine_db_adapter: postgresql, mysql
redmine_db_adapter: "postgresql"
redmine_db_host: "db-1.internal"
redmine_db_port: 5432
redmine_db_name: "redmine"
redmine_db_user: "redmine"
redmine_db_password: "change-me"

# Optional SMTP settings for notifications
# redmine_smtp_enabled: true
# redmine_smtp_address: "smtp.example.com"
# redmine_smtp_port: "587"
# redmine_smtp_user_name: "user"
# redmine_smtp_password: "password"
# redmine_smtp_domain: "example.com"
# redmine_smtp_authentication: "login"
